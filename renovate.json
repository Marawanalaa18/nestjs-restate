{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended",
        ":automergeMinor",
        "group:allNonMajor",
        ":semanticCommits",
        ":pinGitHubActionDigests"
    ],
    "labels": ["dependencies"],
    "minimumReleaseAge": "14 days",
    "packageRules": [
        {
            "groupName": "NestJS",
            "matchPackagePatterns": ["^@nestjs/"],
            "automerge": false
        },
        {
            "groupName": "Restate SDK",
            "matchPackagePatterns": ["^@restatedev/"],
            "automerge": false
        }
    ]
}
